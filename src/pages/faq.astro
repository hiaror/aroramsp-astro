  <script>
    document.querySelectorAll('#faqList .faq-item').forEach((item) => {
      item.addEventListener('click', () => {
        const isOpen = item.getAttribute('aria-expanded') === 'true';
        item.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      });
    });
    document.getElementById('faqExpandAll')?.addEventListener('click', () => {
      document.querySelectorAll('#faqList .faq-item').forEach((i) => i.setAttribute('aria-expanded', 'true'));
    });
    document.getElementById('faqCollapseAll')?.addEventListener('click', () => {
      document.querySelectorAll('#faqList .faq-item').forEach((i) => i.setAttribute('aria-expanded', 'false'));
    });
  </script>
</Layout>
