---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Pricing · AroraMSP"
  description="Fixed-fee Microsoft 365 consulting. Two scoped offers cover 90 percent of engagements; custom work quoted after the discovery call."
  page="pricing"
  canonical="https://aroramsp.com/pricing"
  ogTitle="Pricing - AroraMSP"
  ogDescription="Fixed-fee Microsoft 365 consulting. Two scoped offers cover 90 percent of engagements; custom work quoted after the discovery call."
>
  <section class="page no-center wrap">
    <div class="page-head">
      <div class="sec-label">03 · pricing</div>
      <h2>Fixed-fee projects. No hourly games.</h2>
      <p>Two scoped offers that cover 90% of engagements. Anything custom gets quoted after the discovery call.</p>
    </div>

    <div class="pricing">
      <div class="tier">
        <div class="tier-name">// audit</div>
        <h3>Tenant Health Check</h3>
        <div class="sub">A full read-only audit of your M365 tenant with a prioritised action list.</div>
        <div class="price">
          <span class="amt">$1,500</span>
          <span class="per">· one-time</span>
          <span class="note">USD · delivered in 5 business days</span>
        </div>
        <ul>
          <li>Security and identity review</li>
          <li>License utilization map</li>
          <li>Mail flow and DNS review</li>
          <li>Prioritised findings doc</li>
          <li>60-minute walkthrough call</li>
        </ul>
        <a href="/contact" class="btn btn-ghost">Start an audit →</a>
      </div>

      <div class="tier featured">
        <div class="badge">MOST POPULAR</div>
        <div class="tier-name">// project</div>
        <h3>Migration or Rebuild</h3>
        <div class="sub">End-to-end M365 migration or tenant rebuild. Scoped and fixed-fee.</div>
        <div class="price">
          <span class="amt">from $4,500</span>
          <span class="note">scoped after audit · typically $4.5k to $18k</span>
        </div>
        <ul>
          <li>Everything in the Health Check</li>
          <li>Migration or clean rebuild</li>
          <li>Security baseline and Intune</li>
          <li>SPF / DKIM / DMARC enforced</li>
          <li>Documentation and training session</li>
          <li>30 days post-launch support</li>
        </ul>
        <a href="/contact" class="btn btn-primary">Scope a project →</a>
      </div>
    </div>
  </section>
</Layout>
