logo-a"><path d="M 32,74 L 45.5,42 L 54.5,42 L 68,74 L 59,74 L 50,50 L 41,74 Z" fill="#0a3a6b" transform="translate(1.2 1.2)"/><path d="M 32,74 L 45.5,42 L 54.5,42 L 68,74 L 59,74 L 50,50 L 41,74 Z" fill="#0d4a86" transform="translate(1.0 1.0)"/><path d="M 32,74 L 45.5,42 L 54.5,42 L 68,74 L 59,74 L 50,50 L 41,74 Z" fill="#125b9f" transform="translate(0.8 0.8)"/><path d="M 32,74 L 45.5,42 L 54.5,42 L 68,74 L 59,74 L 50,50 L 41,74 Z" fill="#1d6db5" transform="translate(0.6 0.6)"/><path d="M 32,74 L 45.5,42 L 54.5,42 L 68,74 L 59,74 L 50,50 L 41,74 Z" fill="#3a83c3" transform="translate(0.4 0.4)"/><path d="M 32,74 L 45.5,42 L 54.5,42 L 68,74 L 59,74 L 50,50 L 41,74 Z" fill="#94b5d6" transform="translate(0.2 0.2)"/><path d="M 32,74 L 45.5,42 L 54.5,42 L 68,74 L 59,74 L 50,50 L 41,74 Z" fill="url(#acaF)"/><path d="M 32,74 L 45.5,42 L 54.5,42 L 68,74 L 59,74 L 50,50 L 41,74 Z" fill="url(#acaS)" opacity="0.7"/><path d="M 32,74 L 45.5,42 L 54.5,42 L 68,74 L 59,74 L 50,50 L 41,74 Z" fill="url(#acaT)" opacity="0.9"/><circle cx="50" cy="42" r="6.5" fill="#22d3ee" fill-opacity="0.28"/><circle cx="50" cy="42" r="3.4" fill="#22d3ee"/><circle cx="49" cy="40.6" r="0.9" fill="#ffffff" fill-opacity="0.85"/></g></g><text x="112" y="58" font-family="'Inter','Segoe UI',system-ui,sans-serif" font-size="36" font-weight="700" letter-spacing="-0.6"><tspan fill="#ffffff">Arora</tspan><tspan fill="#0078d4">MSP</tspan></text><text x="113" y="80" font-family="'JetBrains Mono','Inter',ui-monospace,monospace" font-size="15" font-weight="700" letter-spacing="1.5" fill="#ffffff" fill-opacity="1">MICROSOFT 365 CONSULTING</text></svg></a>
